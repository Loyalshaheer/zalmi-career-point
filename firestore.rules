rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Enrollments (public write/update for confirmation, admin read) ──
    match /enrollments/{enrollmentId} {
      allow create: if true;
      allow update: if true; // In a real app, we'd restrict which fields can be changed
      allow read: if request.auth != null;
    }

    // ── Courses (Public read, admin write) ──
    match /courses/{courseId} {
      allow read: if true;
      allow write: if request.auth != null; // Admins handle this via Admin Console

      // Materials inside the course (Classroom Content)
      match /content/{contentId} {
        allow read: if true; // Or restrict to students if needed later
        allow write: if request.auth != null;
      }
    }

    // ── Students (only the student themselves + admins) ──
    match /students/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
