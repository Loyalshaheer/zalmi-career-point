rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Enrollments (public write, admin read) ──
    // Anyone can submit an enrollment form (no auth needed)
    // Only authenticated users can read their own, admins read all
    match /enrollments/{enrollmentId} {
      allow create: if true;  // Public form submission
      allow read, update: if request.auth != null;
    }

    // ── Students (only the student themselves + admins) ──
    match /students/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Sub-collection: enrollments linked to an account
      match /enrollments/{enrollmentId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
