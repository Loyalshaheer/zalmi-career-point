rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if the user is the admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'loyalshaheer05@gmail.com';
    }

    // ── Enrollments ──
    match /enrollments/{enrollmentId} {
      allow create: if request.auth != null; 
      allow read: if isAdmin() || (request.auth != null && request.resource.data.email == request.auth.token.email);
      allow update: if isAdmin() || (request.auth != null && resource.data.email == request.auth.token.email);
      allow delete: if isAdmin();
    }

    // ── Courses ──
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();

      match /content/{contentId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // ── Students ──
    match /students/{userId} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }
  }
}
